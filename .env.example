# ─────────────────────────────────────────
# graphmind-agents — Environment Variables
# Copy this to .env and fill in values
# using git bash command cp .env.example .env
# ─────────────────────────────────────────

# Provider options: groq | openai | google | ollama | anthropic | openrouter | universal
LLM_PROVIDER=groq


# LLM Provider API Key (Groq recommended — free at console.groq.com)
LLM_API_KEY=your_llm_api_key_here

# LLM Model name
LLM_MODEL=llama-3.3-70b-versatile

# Only needed if using 'universal' provider (leave empty otherwise)
LLM_BASE_URL=

# PostgreSQL
POSTGRES_USER=graphmind
POSTGRES_PASSWORD=graphmind_pass
POSTGRES_DB=graphmind_db
DATABASE_URL=postgresql://graphmind:graphmind_pass@db:5432/graphmind_db

# Redis
REDIS_URL=redis://redis:6379/0

# Celery
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# API
API_PORT=8000