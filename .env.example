# ─────────────────────────────────────────
# graphmind-agents — Environment Variables
# Copy this to .env and fill in values
# ─────────────────────────────────────────

# LLM Provider API Key (Groq recommended — free at console.groq.com)
LLM_API_KEY=your_llm_api_key_here

# LLM Provider: groq | openai | google
LLM_PROVIDER=groq

# LLM Model name
LLM_MODEL=llama-3.3-70b-versatile

# PostgreSQL
POSTGRES_USER=graphmind
POSTGRES_PASSWORD=graphmind_pass
POSTGRES_DB=graphmind_db
DATABASE_URL=postgresql://graphmind:graphmind_pass@db:5432/graphmind_db

# Redis
REDIS_URL=redis://redis:6379/0

# Celery
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# API
API_PORT=8000